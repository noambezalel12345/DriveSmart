<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF3FF"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvEditHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EDIT MAINTENANCE"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#3A4FA3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etEditTitle"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Title"
        android:background="@android:drawable/edit_text"
        android:layout_marginTop="24dp"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvEditHeader" />

    <EditText
        android:id="@+id/etEditDescription"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:hint="Description"
        android:gravity="top"
        android:background="@android:drawable/edit_text"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/etEditTitle" />

    <EditText
        android:id="@+id/etEditDueDate"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Select Date"
        android:focusable="false"
        android:clickable="true"
        android:background="@android:drawable/edit_text"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/etEditDescription" />

    <EditText
        android:id="@+id/etEditDueTime"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Select Time"
        android:focusable="false"
        android:clickable="true"
        android:background="@android:drawable/edit_text"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/etEditDueDate" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/swEditRecurring"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Repeat every year"
        android:textColor="#3A4FA3"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/etEditDueTime" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btnBackEdit"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="0.6"
            android:src="@android:drawable/ic_media_previous"
            android:backgroundTint="#1C355E"
            app:tint="@android:color/white" />

        <Button
            android:id="@+id/btnSaveEdit"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.2"
            android:text="SAVE"
            android:layout_marginHorizontal="4dp"
            android:backgroundTint="#3A4FA3" />

        <Button
            android:id="@+id/btnDeleteEdit"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.2"
            android:text="DELETE"
            android:backgroundTint="#D32F2F" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>